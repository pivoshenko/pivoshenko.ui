{
  "name": "pivoshenko.ui",
  "version": "0.2.1",
  "description": "Shared frontend artifacts for the pivoshenko sites (Biome config, TS base, Tailwind preset, React components)",
  "license": "MIT",
  "author": "Volodymyr Pivoshenko",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pivoshenko/pivoshenko.ui.git"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "files": ["config", "tailwind-preset", "ui"],
  "exports": {
    "./biome.json": "./config/biome.json",
    "./tsconfig.base.json": "./config/tsconfig.base.json",
    "./tailwind-preset": {
      "types": "./tailwind-preset/index.d.ts",
      "default": "./tailwind-preset/index.js"
    },
    ".": "./ui/src/index.ts"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "next-themes": "^0.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true },
    "next-themes": { "optional": true },
    "react": { "optional": true },
    "react-dom": { "optional": true },
    "tailwindcss": { "optional": true }
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4"
  }
}
